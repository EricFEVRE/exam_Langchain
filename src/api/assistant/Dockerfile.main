FROM python:3.12-slim
 
WORKDIR /app
 
COPY src/api/assistant/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
 
# Copy core modules
COPY src/core/ ./core/
COPY src/memory/ ./memory/
COPY src/prompts/ ./prompts/
 
# Copy the API entrypoint
COPY src/api/assistant/main.py .

EXPOSE 8000
 
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]